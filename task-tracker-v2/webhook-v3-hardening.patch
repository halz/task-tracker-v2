+const SKIP_TASK_PATTERNS = {
+  senders: [
+    /noreply/i, /no-reply/i, /donotreply/i, /notifications?@/i, /alert@/i,
+    /mailer-daemon/i, /@taskalfa/i, /photoup/i, /franconnect/i,
