+    /sign-?in.*notification/i, /security alert/i, /newsletter/i,
+    /unsubscribe/i, /^marketing/i, /promotional/i, /photoUP/i,
+    /TASKalfa/i, /TGIF/i, /review your emergency contact/i,
+  ],
+};
+
+function shouldCreateTask(email: { from: string; fromName: string; subject: string }): { create: boolean; reason?: string } {
+  for (const pattern of SKIP_TASK_PATTERNS.senders) {
+    if (pattern.test(email.from) || pattern.test(email.fromName)) {
+      return { create: false, reason: `Sender matches skip pattern` };
+    }
+  }
+  for (const pattern of SKIP_TASK_PATTERNS.subjects) {
+    if (pattern.test(email.subject)) {
+      return { create: false, reason: `Subject matches skip pattern` };
+    }
+  }
+  return { create: true };
+}
+
+function isReplyOrForward(subject: string): boolean {
+  return /^(RE:|FW:|Fwd:)/i.test(subject.trim());
+}
+
+function getCleanSubject(subject: string): string {
+  return subject.replace(/^(RE:|FW:|Fwd:)\s*/gi, '').trim();
+}
